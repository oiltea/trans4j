<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://maven.apache.org/POM/4.0.0"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <artifactId>trans4j</artifactId>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <artifactId>maven-compiler-plugin</artifactId>
          <groupId>org.apache.maven.plugins</groupId>
          <version>${maven-compiler-plugin.version}</version>
        </plugin>
        <plugin>
          <artifactId>spring-boot-maven-plugin</artifactId>
          <groupId>org.springframework.boot</groupId>
          <version>${spring-boot.version}</version>
        </plugin>
        <plugin>
          <artifactId>spring-javaformat-maven-plugin</artifactId>
          <groupId>io.spring.javaformat</groupId>
          <version>${spring-javaformat-maven-plugin.version}</version>
        </plugin>
      </plugins>
    </pluginManagement>

    <plugins>
      <plugin>
        <artifactId>spring-javaformat-maven-plugin</artifactId>
        <groupId>io.spring.javaformat</groupId>
      </plugin>
    </plugins>
  </build>
  <dependencyManagement>
    <dependencies>
      <!-- Spring -->
      <dependency>
        <artifactId>spring-boot-dependencies</artifactId>
        <groupId>org.springframework.boot</groupId>
        <scope>import</scope>
        <type>pom</type>
        <version>${spring-boot.version}</version>
      </dependency>

      <!-- Modules -->
      <dependency>
        <artifactId>trans4j-core</artifactId>
        <groupId>io.github.oiltea</groupId>
        <version>${project.version}</version>
      </dependency>

      <dependency>
        <artifactId>lombok</artifactId>
        <groupId>org.projectlombok</groupId>
        <version>${lombok.version}</version>
      </dependency>
    </dependencies>
  </dependencyManagement>
  <description>trans4j</description>
  <developers>
    <developer>
      <email>oiltea@qq.com</email>
      <name>oiltea</name>
    </developer>
  </developers>

  <groupId>io.github.oiltea</groupId>
  <licenses>
    <license>
      <name>The Apache Software License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
    </license>
  </licenses>
  <modelVersion>4.0.0</modelVersion>

  <modules>
    <module>trans4j-core</module>
    <module>trans4j-jackson2-spring-boot-starter</module>
    <module>trans4j-jackson3-spring-boot-starter</module>
  </modules>

  <name>${project.groupId}:${project.artifactId}</name>

  <packaging>pom</packaging>

  <properties>
    <java.version>17</java.version>
    <lombok.version>1.18.42</lombok.version>
    <maven-compiler-plugin.version>3.14.1</maven-compiler-plugin.version>
    <maven.compiler.source>${java.version}</maven.compiler.source>

    <!-- Spring -->
    <maven.compiler.target>${java.version}</maven.compiler.target>

    <!-- Compiler -->
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!-- Plugin -->
    <spring-boot.version>4.0.1</spring-boot.version>
    <spring-javaformat-maven-plugin.version>0.0.47</spring-javaformat-maven-plugin.version>
  </properties>

  <scm>
    <connection>scm:git:git://github.com/oiltea/fastboot.git</connection>
    <developerConnection>scm:git:ssh://github.com:oiltea/fastboot.git</developerConnection>
    <url>http://github.com/oiltea/fastboot/tree/master</url>
  </scm>

  <url>https://github.com/oiltea/trans4j</url>

  <version>1.0.0</version>
</project>